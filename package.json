{
  "name": "sumsuma-mobile",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web:dev": "expo start --web --port 5000 --host lan",
    "build:web": "expo export --platform web",
    "build": "npm run build:web",
    "web": "npm run build:web && npx serve dist -l 5000",
    "test:remittance": "ts-node --project scripts/tsconfig.json scripts/runRemittanceTests.ts",
    "worker:settlement": "ts-node --project scripts/tsconfig.json scripts/runSettlementWorker.ts",
    "worker:recurring-support": "ts-node --project scripts/tsconfig.json scripts/runRecurringSupportWorker.ts",
    "server:admin": "ts-node --transpile-only --project server/tsconfig.json server/index.ts",
    "test:risk": "jest server/tests/riskControls.test.ts --no-coverage",
    "test": "jest --no-coverage",
    "emulator:firestore": "firebase emulators:start --only firestore",
    "test:emulator": "firebase emulators:exec --only firestore \"node scripts/runFirestoreEmulatorTests.js\"",
    "typecheck": "tsc --noEmit --project server/tsconfig.json",
    "test:load": "ts-node --transpile-only --project server/tsconfig.json server/tests/concurrentLoad.ts"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.0",
    "@expo/vector-icons": "~14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.11.0",
    "@tanstack/react-query": "^5.17.9",
    "axios": "^1.6.5",
    "cors": "^2.8.6",
    "expo": "~52.0.0",
    "expo-clipboard": "~7.0.0",
    "expo-device": "~7.0.3",
    "expo-font": "~13.0.0",
    "expo-haptics": "~14.0.0",
    "expo-image-picker": "~16.0.0",
    "expo-linking": "~7.0.5",
    "expo-local-authentication": "~15.0.0",
    "expo-localization": "~16.0.1",
    "expo-notifications": "~0.29.0",
    "expo-secure-store": "~14.0.0",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "firebase": "^10.14.1",
    "firebase-admin": "^13.7.0",
    "i18next": "^23.7.16",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "^14.0.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.10",
    "serve": "^14.2.5",
    "stripe": "^20.4.1",
    "stripe-replit-sync": "^1.0.0",
    "tailwindcss": "3.3.5"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/types": "^7.29.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/react": "~18.3.0",
    "@types/supertest": "^7.2.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "firebase-tools": "^15.22.4",
    "jest": "^29.3.1",
    "node-cron": "^4.2.1",
    "patch-package": "^8.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "private": true
}
