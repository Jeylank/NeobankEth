{
  "expo": {
    "name": "Sumsuma",
    "slug": "sumsuma-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sumsuma.mobile"
    },
    "android": {
      "package": "com.sumsuma.mobile"
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "sumsuma-mobile"
      }
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
