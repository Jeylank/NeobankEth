# API Configuration
# Replace with your actual NeoBanker API URL
EXPO_PUBLIC_API_URL=https://your-neobanker-app.replit.app

# Firebase Configuration
# Get these from your Firebase Console
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-app-id

# Server-only Firebase Admin credentials for Replit Secrets.
# Use one of these. Do not commit real service account JSON.
FIREBASE_SERVICE_ACCOUNT_JSON={"project_id":"your-project-id","client_email":"firebase-adminsdk@example.iam.gserviceaccount.com","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}
# FIREBASE_SERVICE_ACCOUNT_BASE64=base64-encoded-service-account-json
